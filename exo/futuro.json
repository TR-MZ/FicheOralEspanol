{
  "id": "futuro",
  "title": "Futur simple",
  "rule": "Le futur sert à prévoir, imaginer des conséquences ou annoncer ce qui arrivera. Les terminaisons sont les mêmes pour -ar, -er, -ir.",
  "examples": [
    "España tendrá que ahorrar agua.",
    "Las redes cambiarán la vida de los jóvenes.",
    "El debate será importante."
  ],
  "exercises": [
    { "id": "futuro-001", "type": "conjugaison", "prompt": "Conjugue au futur : España _____ (tener) que ahorrar agua.", "answer": "España tendrá que ahorrar agua.", "hint": "tener -> tendrá." },
    { "id": "futuro-002", "type": "conjugaison", "prompt": "Conjugue : Los jóvenes _____ (usar) nuevas tecnologías.", "answer": "Los jóvenes usarán nuevas tecnologías.", "hint": "ellos : -án." },
    { "id": "futuro-003", "type": "conjugaison", "prompt": "Conjugue : Nosotros _____ (estudiar) la propaganda.", "answer": "Nosotros estudiaremos la propaganda.", "hint": "nosotros : -emos." },
    { "id": "futuro-004", "type": "conjugaison", "prompt": "Conjugue : La ley _____ (proteger) a los menores.", "answer": "La ley protegerá a los menores.", "hint": "él/ella : -á." },
    { "id": "futuro-005", "type": "conjugaison", "prompt": "Conjugue : Yo _____ (hacer) un resumen.", "answer": "Yo haré un resumen.", "hint": "hacer -> haré." },
    { "id": "futuro-006", "type": "conjugaison", "prompt": "Conjugue : Tú _____ (poder) explicar el documento.", "answer": "Tú podrás explicar el documento.", "hint": "poder -> podrás." },
    { "id": "futuro-007", "type": "traduction", "prompt": "Traduis : Les politiciens utiliseront des images.", "answer": "Los políticos usarán imágenes.", "hint": "usar au futur." },
    { "id": "futuro-008", "type": "conjugaison", "prompt": "Conjugue : El clima _____ (cambiar) mucho.", "answer": "El clima cambiará mucho.", "hint": "cambiará." },
    { "id": "futuro-009", "type": "conjugaison", "prompt": "Conjugue : Vosotros _____ (ver) las consecuencias.", "answer": "Vosotros veréis las consecuencias.", "hint": "vosotros : -éis." },
    { "id": "futuro-010", "type": "choix", "prompt": "Choisis : En el futuro, España (tendrá / tuvo) menos agua.", "answer": "En el futuro, España tendrá menos agua.", "hint": "En el futuro -> futur." },
    { "id": "futuro-011", "type": "conjugaison", "prompt": "Conjugue : Las familias _____ (necesitar) más ayudas.", "answer": "Las familias necesitarán más ayudas.", "hint": "ellos/ellas : -án." },
    { "id": "futuro-012", "type": "transformation", "prompt": "Mets au futur : El debate es difícil.", "answer": "El debate será difícil.", "hint": "ser -> será." }
  ]
}
